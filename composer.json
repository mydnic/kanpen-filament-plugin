{
    "name": "mydnic/kanpen-filament-plugin",
    "description": "A Filament plugin to manage your Kanpen Campaigns and Subscribers",
    "keywords": [
        "Mydnic",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "kanpen-filament-plugin"
    ],
    "homepage": "https://github.com/mydnic/kanpen-filament-plugin",
    "support": {
        "issues": "https://github.com/mydnic/kanpen-filament-plugin/issues",
        "source": "https://github.com/mydnic/kanpen-filament-plugin"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Mydnic",
            "email": "rigoclement@mydnic.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "mydnic/kanpen": "^2.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mydnic\\KanpenFilamentPlugin\\": "src/",
            "Mydnic\\KanpenFilamentPlugin\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mydnic\\KanpenFilamentPlugin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "lint": "pint",
        "test": "pest",
        "test:lint": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mydnic\\KanpenFilamentPlugin\\KanpenFilamentPluginServiceProvider"
            ],
            "aliases": {
                "KanpenFilamentPlugin": "Mydnic\\KanpenFilamentPlugin\\Facades\\KanpenFilamentPlugin"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
